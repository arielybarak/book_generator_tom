# Copy to .env. The public HF Space id that serves the /generate_page API.
VITE_HF_SPACE=MLightning/text2STL-engine-2.0-superMX-bottom

# SERVER-SIDE ONLY (no VITE_ prefix → never shipped to the browser).
# Set in the Vercel project (Settings → Environment Variables), do NOT commit.
# A PRO Hugging Face account token: api/generate.js attaches it so generations
# run on the owner's PRO ZeroGPU quota instead of the (tiny) anonymous pool.
# HF_TOKEN=hf_xxx
# HF_SPACE=MLightning/text2STL-engine-2.0-superMX-bottom   # optional; defaults to above
